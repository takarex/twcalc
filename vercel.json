{
  "version": 2,
  "builds": [{ "src": "**/*.html", "use": "@vercel/static" }],
  "routes": [
    { "src": "/google([a-z0-9]+)\\.html", "dest": "/google$1.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
